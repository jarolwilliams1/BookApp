<h2 class="crearLibro-text">Editar libro</h2>
<div class="linea-libros"></div>

<section class="editarlibro-section container">

{{#if sinDatos}}

<p class="advertencia">No hay categorías, autores o editoriales creadas.</p>

<div class="botones">
    <a type="button" class="btn btn-outline-secondary bt-cancelar" href="/libros">Volver</a>
</div>

{{else}}

<form action="/editarlibro/{{libro.libroid}}" method="post">


<div class="mb-3 group-input">
  <label for="titulo-libro" class="form-label">Título del libro <span class="asterisco">*</span></label>
  <input type="text" class="form-control" id="titulo-libro" name="titulo" value="{{libro.titulo}}" placeholder="Ej. Cien anos de soledad" required>
</div>

<div class="mb-3  group-input">
  <label for="ano-pulicacion" class="form-label">Año de publicación <span class="asterisco">*</span></label>
  <input type="number" class="form-control" id="ano-pulicacion" name="year" value="{{libro.year}}" placeholder="Ej. 1967" required>
</div>

<div class= " mb-3 vizualizar">
    <img src="{{libro.urlimagen}}" alt="" class="vizualizar-img">

    <div class="vizualizar-text">
        <h6 class="PORTADA-ACTUAL">PORTADA ACTUAL</h6>
        <p>Si ingresas una nueva URL, esta portada será reemplazada.</p>
    </div>
</div>

<div class="mb-3  group-input">
  <label for="url-img" class="form-label">URL de la imagen de portada</label>
  <input type="url" class="form-control" id="url-img" name="urlimagen" placeholder="https://...">
</div>

<div class="select">
    <label for="">Categoría <span class="asterisco">*</span></label>
    <select class="form-select" name="categoriaid" aria-label="Default select example" required>
  {{#each categorias}}
  <option value="{{categoriaid}}" {{#if seleccionada}}selected{{/if}}>{{nombrecategoria}}</option>
  {{/each}}
</select>
</div>

<div class="select">
    <label for="">Autor <span class="asterisco">*</span></label>
    <select class="form-select" name="autorid" aria-label="Default select example" required>
  {{#each autores}}
  <option value="{{autorid}}" {{#if seleccionado}}selected{{/if}}>{{nombreautor}}</option>
  {{/each}}
</select>
</div>


<div class="select">
    <label for="">Editorial <span class="asterisco">*</span></label>
    <select class="form-select" name="editorialid" aria-label="Default select example" required>
  {{#each editoriales}}
  <option value="{{editorialid}}" {{#if seleccionada}}selected{{/if}}>{{nombreeditorial}}</option>
  {{/each}}
</select>
</div>

<div class="botones">
    <button type="submit" class="btn btn-success btn-crarlibro" >Actualizar libro</button>
    <a type="button" class="btn btn-outline-secondary bt-cancelar" href="/libros">Cancelar</a>

</div>


</form>

{{/if}}

</section>
