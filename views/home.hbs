<section class="home-head">
    <img src="" alt="">

    <div class="home-text-head">
        <h1 class="home-title">Catálogo de Libros</h1>
        <p class="home-text">Explora nuestra colección completa de títulos disponibles</p>
    </div>
</section>

<section class=" container buscar-section ">

    <form action="/" method="get">
    
    <div class="row buscar-container">
    <div class="col-lg-5 col-md-12 ">

  <label for="buscar-Bytitulo" class="form-label">Buscar por título</label>
  <input type="text" class="form-control buscar-Bytitulo" id="buscar-Bytitulo" name="titulo" value="{{titulo}}" placeholder="Buscar por titulo del libro..">

    </div>

    <div class="col-lg-5 col-md-6 ">

        <label for="">Filtrar por categorías</label>

<div class="checkbox-container">

{{#each categorias}}
  <div class="form-check">
    <input class="form-check-input" type="checkbox" name="categorias" value="{{categoriaid}}" id="categoria-{{categoriaid}}" {{#if marcada}}checked{{/if}}>
    <label class="form-check-label" for="categoria-{{categoriaid}}">
      {{nombrecategoria}}
    </label>
  </div>
{{/each}}

</div>


    </div>

  <div class="col-lg-2 col-md-6">
          <button class="  btn-filtrar   " type="submit"><img src="" alt=""> Filtrar</button>

  </div>
   
  </div>

</form>
    
</section>


<section class="libros">

{{#each libros}}
     <div class="card" style="width: 18rem;" >
        <a href="/info-libro/{{libroid}}">

  <img src="{{urlimagen}}" class="card-img-top" alt="...">
  <div class="card-body">
    <h5 class="card-title">{{titulo}}</h5>
    <p class="card-year"><img src="" alt=""> {{year}}</p>
    <div class="card-category">{{categoria.nombrecategoria}}</div>
        <p class="card-autor"><img src="" alt="">{{autor.nombreautor}}</p>
    <p class="card-editorial"><img src="" alt=""> {{editorial.nombreeditorial}}</p>

  </div>
    </a>

</div>
{{else}}
  <p class="p-libros">No hay libros registrados.</p>
{{/each}}
</section>
