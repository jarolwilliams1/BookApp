<div class="text-libros-container">
    <h2 class="title-libros">Mantenimiento de Categorías</h2>
<p class="p-libros">Gestión completa de las categorías del catálogo.</p>
</div>

<div class="linea-libros"></div>

<section class="libros-container">
    <div class="head-libros">
        <p class="registros-libros"> {{categorias.length}} registro(s)</p>
        <a type="button" class="btn btn-success btn-crearlibro" href="/categoria/crear">+ Crear categoría nueva</a>
    </div>

   <table class="libros-tabla">
  <thead>
    <tr class="tr-th">
      <th>NOMBRE</th>
      <th>DESCRIPCIÓN</th>
      <th>LIBROS</th>
      <th>ACCIONES</th>
    </tr>
  </thead>

  <tbody>
    {{#each categorias}}
    <tr>
      <td>{{nombrecategoria}}</td>
      <td>{{descripcioncategoria}}</td>
      <td>{{cantidadLibros}}</td>
      <td class="contenedor-btn">
        <a type="button" class="btn btn-warning" href="/categoria/editar/{{categoriaid}}">Editar</a>
        <button type="button" class="btn btn-danger eliminar-categoria-btn" data-eliminar-url="/categoria/eliminar/{{categoriaid}}" data-eliminar-nombre="{{nombrecategoria}}">Eliminar</button>
      </td>
    </tr>
    {{else}}
    <tr>
      <td colspan="4">No hay categorías registradas.</td>
    </tr>
    {{/each}}
  </tbody>
</table>

<div class="eliminar-libro" id="eliminar-categoria-card" hidden >

 <div class="text-card-eliminar-libro">
   <h3 class="pregunta">¿Eliminar este registro?</h3>
  <p class="p-pregunta">¿Está seguro que desea eliminar esta categoría?</p>
  <h4 class="nombre-libro" id="nombre-categoria-seleccionada"></h4>
  <p class="advertencia">Esta acción no puede deshacerse.</p>
 </div>
  <div class="btns-eliminar-card">
    <button type="button" class="btn btn-secondary btn-eliminar-libro-card" id="btn-cancelar-categoria-card">Cancelar</button>
    <form id="form-eliminar-categoria" action="" method="post">
      <button type="submit" class="btn btn-danger btn-cancelar-libro-card" id="btn-eliminar-categoria-card">Aceptar, eliminar</button>
    </form>
  </div>
</div>

</section>
