<h2 class="crearLibro-text">Editar autor</h2>
<div class="linea-libros"></div>

<section class="crearlibro-section container">

<form action="" method="get">


<div class="mb-3 group-input">
  <label for="titulo-libro" class="form-label">Nombre del autor <span class="asterisco">*</span></label>
  <input type="text" class="form-control" id="titulo-libro" placeholder="Ej. Gabriel Garcia Marquez" required>
</div>


<div class="mb-3 group-input">
  <label for="titulo-libro" class="form-label">Correo del autor <span class="asterisco">*</span></label>
  <input type="email" class="form-control" id="titulo-libro" placeholder="autor@ejemplo.com" required>
</div>



<div class="botones">
    <button type="submite" class="btn btn-success btn-crarlibro" >Guardar categoria</button>
    <a type="button" class="btn btn-outline-secondary bt-cancelar" href="/autores">Cancelar</a>

</div>


</form>

</section>